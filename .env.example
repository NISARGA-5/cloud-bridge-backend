# ── COPY TO .env AND FILL IN ──────────────────────────────
# cp .env.example .env

# ── APP ───────────────────────────────────────────────────
FLASK_ENV=development         # change to: production  on Azure/GCP
SECRET_KEY=change-this-to-random-secret

# ── DATABASE ──────────────────────────────────────────────
# LOCAL — SQLite (no config needed, auto-created)
# DATABASE_URL is the file path for SQLite (set in config.py)

# AZURE MariaDB (uncomment when deploying)
# DATABASE_URL=mysql+pymysql://adminuser:YourPass@cloudbridge-db.mariadb.database.azure.com/cloudbridge

# GCP Cloud SQL (uncomment when deploying)
# DATABASE_URL=mysql+pymysql://root:YourPass@/cloudbridge?unix_socket=/cloudsql/PROJECT:REGION:INSTANCE

# ── STORAGE ───────────────────────────────────────────────
STORAGE_TYPE=local             # local | azure | gcp

# AZURE BLOB
# STORAGE_TYPE=azure
# AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_CONTAINER=cloudbridge-files

# GCP CLOUD STORAGE
# STORAGE_TYPE=gcp
# GCP_BUCKET_NAME=cloudbridge-files

# ── EMAIL (Gmail SMTP) ────────────────────────────────────
# Leave empty locally — OTP will show on screen instead
# Fill in on Azure/GCP for real email sending
MAIL_USERNAME=
MAIL_PASSWORD=
# How to get Gmail App Password:
# 1. Google Account → Security → Enable 2-Step Verification
# 2. Search "App passwords" → create one → copy the 16-char password
